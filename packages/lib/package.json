    },
    "./supabase/roles": {
      "import": "./src/supabase/roles.ts",
      "types": "./src/supabase/roles.ts"
    },
    "./firebase/client": {
      "import": "./src/firebase/client.ts",
      "types": "./src/firebase/client.ts"
    },
