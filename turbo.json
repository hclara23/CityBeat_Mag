{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.local", "**/.env"],
  "pipeline": {
    "dev": {
      "cache": false,
      "interactive": true
    },
    "build": {
      "outputs": [".next/**", "dist/**", "build/**"],
      "dependsOn": ["^build"]
    },
    "start": {
      "cache": false,
      "interactive": true
    },
    "lint": {
      "outputs": [],
      "cache": false
    },
    "type-check": {
      "outputs": [],
      "cache": false
    }
  }
}
