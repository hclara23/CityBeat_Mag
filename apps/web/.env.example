# Public Environment Variables (exposed to browser)
NEXT_PUBLIC_SITE_URL=https://citybeatmag.co
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2021-06-07
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Secret Environment Variables (server-side only)
SANITY_API_TOKEN=your_sanity_read_token

# Analytics & Tracking
NEXT_PUBLIC_TRACKING_ENDPOINT=/api/tracking
# Comma-separated IPs whose page views are NOT counted in first-party analytics
# (e.g. office/home). Signed-in staff are excluded automatically regardless.
ANALYTICS_EXCLUDED_IPS=
NEXT_PUBLIC_WORKER_URL=https://api.citybeatmag.co
NEXT_PUBLIC_APP_URL=https://citybeatmag.co
NEXT_PUBLIC_ADS_URL=https://citybeatmag.co/ads
NEXT_PUBLIC_STUDIO_URL=https://citybeatmag.co/studio

# --- Ticketmaster affiliate (optional; earns commission on ticket sales) ---
# Sign up via Ticketmaster's affiliate program on Impact.com, then set ONE:
#   Redirect/deep-link wrapper with a literal {url} placeholder:
# TICKETMASTER_AFFILIATE_WRAP=https://ticketmaster.evyy.net/c/PUBID/CAMPID/APIID?u={url}
#   OR tracking params to append to the Ticketmaster URL:
# TICKETMASTER_AFFILIATE_PARAMS=irgwc=1&clickid=YOUR_ID

# ── LLM observability (Langfuse) ──────────────────────────────────────────────
# Optional. When all three are set, every Claude call is traced to Langfuse
# (prompt, response, tokens, latency, per-feature). Fully dormant/no-op if unset.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com   # US cloud (default); or https://cloud.langfuse.com (EU) / your self-host URL
