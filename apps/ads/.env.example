# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_your_public_key
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Sentry Configuration (Error Tracking)
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Application URLs
NEXT_PUBLIC_APP_URL=https://ads.citybeatmag.co
NEXT_PUBLIC_API_URL=https://api.citybeatmag.co

# Email Configuration
RESEND_API_KEY=re_your_resend_api_key

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SENTRY=true

# Vercel Environment
VERCEL_ENV=production
VERCEL_URL=ads.citybeatmag.co
