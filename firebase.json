{
  "hosting": [
    {
      "target": "web",
      "public": "firebase-public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "run": {
            "serviceId": "citybeat-web",
            "region": "us-central1"
          }
        }
      ]
    },
    {
      "target": "ads",
      "public": "firebase-public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "run": {
            "serviceId": "citybeat-ads",
            "region": "us-central1"
          }
        }
      ]
    }
  ]
}
