      "updateInterval": 1800,
      "keywords": ["breaking", "update", "alert"],
      "geoFilter": {
        "areas": ["el-paso-county"]
      }
    },
    {
      "id": "newsapi-ep",
      "name": "NewsAPI - El Paso",
      "type": "newsapi",
      "url": "https://newsapi.org/v2/everything",
      "category": "news",
      "enabled": true,
      "priority": 2,
      "updateInterval": 3600,
      "keywords": ["El Paso", "Ciudad Juárez", "border", "New Mexico"],
      "apiKey": "${NEWS_API_KEY}",
      "geoFilter": {
        "areas": ["el-paso-county", "horizon", "socorro", "clint", "las-cruces"]
      }
    }
  ],
  "geoAreas": {
    "el-paso-county": {
      "name": "El Paso County",
      "center": {
        "lat": 31.7683,
        "lng": -106.4425
      },
      "radius_km": 30
    },
    "horizon": {
      "name": "Horizon",
      "center": {
        "lat": 31.8706,
        "lng": -106.5694
      },
      "radius_km": 15
    },
    "socorro": {
      "name": "Socorro",
      "center": {
        "lat": 31.6597,
        "lng": -106.4056
      },
      "radius_km": 10
    },
    "clint": {
      "name": "Clint",
      "center": {
        "lat": 31.5394,
        "lng": -106.2544
      },
      "radius_km": 8
    },
    "las-cruces": {
      "name": "Las Cruces",
      "center": {
        "lat": 32.6397,
        "lng": -106.4621
      },
      "radius_km": 20
    }
  },
  "contentFilters": {
    "excludeKeywords": [
      "spam",
      "advertisement",
      "clickbait",
      "fake news"
    ],
    "includeKeywords": {
      "news": ["breaking", "breaking news", "developing", "update"],
      "business": ["business", "company", "startup", "job", "hiring", "earnings"],
      "events": ["event", "concert", "festival", "conference", "meeting"],
      "culture": ["art", "culture", "museum", "theater", "performance", "artist"]
    }
  },
  "translationConfig": {
    "sourceLanguage": "en",
    "targetLanguage": "es",
    "translateHeadlines": true,
    "translateContent": true,
    "service": "deepl"
  }
}
